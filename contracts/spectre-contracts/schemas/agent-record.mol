// AgentRecord: on-chain state for a Spectre-protected agent cell.

array Byte32 [byte;32];
array Uint64 [byte;8];
vector Bytes <byte>;

table AgentRecord {
    email_hash:           Byte32,
    identity_commitment:  Byte32,
    owner_pubkey:         Bytes,
    timelock_blocks:      Uint64,
    nonce:                Uint64,
    // Packed blake160 hashes: N x 20 bytes
    guardians: Bytes,
    // m in m-of-n; 0 = guardian recovery disabled
    guardian_threshold: Uint64,
     // 33 bytes during recovery, 0 bytes otherwise
    pending_owner_pubkey:  Bytes,  
}